# ---- Server ----
PORT=3000
# Public base URL of THIS server (from ngrok or your host), no trailing slash.
# Example: https://abc123.ngrok-free.app
PUBLIC_BASE_URL=

# ---- Twilio ----
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Your Twilio voice-capable number in E.164, e.g. +1XXXXXXXXXX (your caller ID / from-number)
TWILIO_PHONE_NUMBER=

# ---- Sarvam AI (STT + TTS, Indian languages) ----
# Get from https://dashboard.sarvam.ai
SARVAM_API_KEY=
# TTS voice (Bulbul). Telugu-capable speakers: Anushka, Manisha, Vidya, Arya, Abhilash, Karun, Hitesh
SARVAM_TTS_SPEAKER=Anushka
SARVAM_TTS_MODEL=bulbul:v2
SARVAM_STT_MODEL=saarika:v2.5

# ---- Brain (the LLM that runs the conversation) ----
# Provider: "openai" (recommended for reliable tool use) or "sarvam" (Indic-native, fewer keys)
BRAIN_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
# Only if BRAIN_PROVIDER=sarvam (reuses SARVAM_API_KEY):
SARVAM_CHAT_MODEL=sarvam-m

# ---- Escalation ----
# Number to transfer urgent calls to (clinic staff), E.164. Leave blank to disable transfer.
CLINIC_ESCALATION_NUMBER=

# ---- Admin login (dashboard Basic Auth) ----
# Protects the dashboard + APIs. Twilio webhooks and the health check stay open.
# Leave both blank to disable the login (local dev only).
ADMIN_USER=
ADMIN_PASSWORD=
